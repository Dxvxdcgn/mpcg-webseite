<Layout title="Impressum" description="Impressum der MPCG GmbH, Hohenzollernring 25, 50672 Köln.">

  <section class="pt-32 pb-16 bg-primary">
    <div class="container-custom">
      <h1 class="text-3xl md:text-5xl font-bold text-white">Impressum</h1>
    </div>
  </section>

  <section class="section-padding bg-white">
    <div class="container-custom">
      <div class="max-w-3xl mx-auto prose prose-lg prose-gray">

        <h2 class="text-2xl font-bold text-primary mt-8 mb-4">Angaben gemäß § 5 TMG</h2>
        <p class="text-text-light leading-relaxed mb-6">
          MPCG GmbH<br/>
          Hohenzollernring 25<br/>
          50672 Köln
        </p>

        <h2 class="text-2xl font-bold text-primary mt-8 mb-4">Vertreten durch</h2>
        <p class="text-text-light leading-relaxed mb-6">
          Geschäftsführer: Marco Pister
        </p>

        <h2 class="text-2xl font-bold text-primary mt-8 mb-4">Kontakt</h2>
