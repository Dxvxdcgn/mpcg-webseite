---

<Layout title="Insights" description="MPCG Insights – Aktuelle Themen und Trends aus der Managementberatung.">

  <Hero
    title='Unsere <span class="gradient-text">Insights</span>'
    subtitle="Wissen & Trends"
    description="Aktuelle Themen, Trends und Erfahrungen aus unserer Beratungspraxis. Wir teilen unser Wissen und unsere Erkenntnisse mit Ihnen."
    compact={true}
    backgroundImage="/imgi_48_Insights-Desktop.jpg"
  />

  <section class="section-padding bg-white">
    <div class="container-custom">
      <!-- Category Filter -->
      <div class="flex flex-wrap gap-2 mb-12 justify-center fade-in" id="insight-filter">
        {categories.map((cat) => (
          <button
            data-category={cat}
            class={`px-4 py-2 rounded-full text-sm font-medium transition-all duration-300 border backdrop-blur-sm ${cat === 'Alle' ? 'bg-accent text-white border-accent shadow-sm shadow-accent/20' : 'bg-white text-text-light border-gray-200/80 hover:border-accent/40 hover:text-accent hover:bg-accent/[0.03]'}`}
          >
            {cat}
          </button>
        ))}
      </div>

      <!-- Articles Grid -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5 fade-in stagger-children" id="articles-grid">
        {articles.map((article) => (
          <article class="group bg-white rounded-2xl overflow-hidden border border-gray-100/80 card-hover glow" data-article-category={article.category}>
            <div class="p-6">
              <span class="tag tag-accent mb-3">{article.category}</span>
              <h2 class="text-lg font-bold text-primary mb-3 group-hover:text-accent transition-colors tracking-tight">{article.title}</h2>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding bg-primary text-white relative overflow-hidden grain">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-accent/[0.06] rounded-full blur-[120px]"></div>
      <div class="absolute bottom-0 left-0 w-[300px] h-[300px] bg-accent-light/[0.04] rounded-full blur-[80px]"></div>
    </div>
    <div class="container-custom relative text-center fade-in">
      <h2 class="text-3xl md:text-5xl font-extrabold mb-6 tracking-tight">Haben Sie Fragen?</h2>
      <p class="text-white/50 text-lg max-w-2xl mx-auto mb-10 font-light">
        Wir freuen uns auf den Austausch mit Ihnen. Kontaktieren Sie uns für ein unverbindliches Gespräch.
      </p>
      <a href="/kontakt" class="btn-primary">
        Kontakt aufnehmen
        <Icon name="lucide:arrow-right" class="w-5 h-5 ml-2" />
      </a>
    </div>
  </section>

</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const buttons = document.querySelectorAll('#insight-filter button');
    const articles = document.querySelectorAll('#articles-grid > article');

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const cat = btn.dataset.category;

        buttons.forEach(b => {
          b.classList.remove('bg-accent', 'text-white', 'border-accent');
          b.classList.add('bg-white', 'text-text-light', 'border-gray-200');
        });
        btn.classList.remove('bg-white', 'text-text-light', 'border-gray-200');
        btn.classList.add('bg-accent', 'text-white', 'border-accent');

        articles.forEach(a => {
          const el = a as HTMLElement;
          if (cat === 'Alle' || el.dataset.articleCategory === cat) {
            el.style.display = '';
          } else {
            el.style.display = 'none';
          }
        });
      });
    });
  });
</script>