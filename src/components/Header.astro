---
import { Icon } from 'astro-icon/components';

const navItems = [
  { label: 'Leistungen', href: '/leistungen', children: [
    { heading: 'Agilere Organisation', href: '/leistungen/agile-organisation', items: [
      'Organisationsentwicklung', 'Change Management', 'Digitale Organisation',
      'Unternehmenssteuerung', 'Unternehmensziele', 'Mensch & Kultur',
    ]},
    { heading: 'Effizientere Prozesse', href: '/leistungen/effizientere-prozesse', items: [
      'Prozessexzellenz', 'Prozessoptimierung', 'Prozessdigitalisierung',
      'Prozessentwicklung', 'Prozessmodellierung',
    ]},
    { heading: 'Mehr Sales', href: '/leistungen/mehr-sales', items: [
      'Sales Exzellenz', 'Digital Marketing', 'Sales Development',
      'E-Commerce', 'Omni-Channel-Management', 'CRM',
    ]},
    { heading: 'Tiefgreifende Nachhaltigkeit', href: '/leistungen/nachhaltigkeit', items: [
      'CSRD-Reporting', 'Hotspot-Analyse', 'SDG-Analyse',
    ]},
    { heading: 'Bessere Strategie', href: '/leistungen/bessere-strategie', items: [
      'Digitalstrategie', 'Strategic Positioning', 'Geschäftsentwicklung',
      'Vertriebsstrategie', 'Contentstrategie',
    ]},
  ]},
  { label: 'Erfolge', href: '/erfolge' },
  { label: 'Wer wir sind', href: '/wer-wir-sind' },
  { label: 'Karriere', href: '/karriere' },
  { label: 'Insights', href: '/insights' },
  { label: 'Kontakt', href: '/kontakt' },
];
---

<header id="main-header" class="fixed top-0 left-0 w-full z-50 transition-all duration-500" style="background: transparent;">
  <div class="container-custom">
    <nav class="flex items-center justify-between h-18 md:h-20">
      <a href="/" class="flex items-center gap-3 group shrink-0">
        <img src="/imgi_2_mpcg-koeln-logo.svg" alt="MPCG Logo" class="h-6 md:h-7 logo-img brightness-0 invert transition-all duration-500" />
      </a>

      <div class="hidden lg:flex items-center gap-0.5 bg-white/[0.06] backdrop-blur-md rounded-full px-1.5 py-1 border border-white/[0.08]" id="nav-pill">
        {navItems.map((item) => (
          <div class="relative group">
            <a
              href={item.href}
              class="nav-link text-white/90 px-4 py-2 text-[13px] font-medium transition-all duration-300 hover:text-white rounded-full hover:bg-white/10 inline-flex items-center gap-1"
            >
              {item.label}
              {item.children && (
                <Icon name="lucide:chevron-down" class="w-3 h-3 opacity-50 group-hover:opacity-100 transition-opacity group-hover:rotate-180 duration-300" />
              )}
            </a>
            {item.children && (
              <div class="absolute top-full left-1/2 -translate-x-1/2 pt-4 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform group-hover:translate-y-0 translate-y-3">
                <div class="bg-white/95 backdrop-blur-xl rounded-2xl shadow-2xl shadow-black/8 border border-gray-200/50 p-6 grid grid-cols-3 gap-x-8 gap-y-2 min-w-[680px]">
                  {item.children.map((group: any) => (
                    <div class="min-w-0">
                      <a href={group.href} class="block text-[13px] font-bold text-primary hover:text-accent transition-colors mb-2.5 pb-2 border-b border-gray-100">
                        {group.heading}
                      </a>
                      <div class="space-y-0.5">
                        {group.items.map((sub: string) => (
                          <a href={group.href} class="block px-2.5 py-1.5 text-xs text-gray-500 hover:text-accent hover:bg-accent/5 rounded-lg transition-all duration-200">
                            {sub}
                          </a>
                        ))}
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
        ))}
      </div>

      <div class="hidden lg:flex items-center gap-3">
        <a href="https://www.linkedin.com/company/mpcg-koeln/" target="_blank" rel="noopener" class="nav-link text-white/80 w-9 h-9 flex items-center justify-center hover:text-white hover:bg-white/10 rounded-full transition-all duration-300" aria-label="LinkedIn">
          <Icon name="lucide:linkedin" class="w-4 h-4" />
        </a>
        <a href="/kontakt" class="inline-flex items-center px-5 py-2 bg-white/10 backdrop-blur-sm text-white text-[13px] font-semibold rounded-full transition-all duration-300 hover:bg-accent hover:shadow-lg hover:shadow-accent/25 border border-white/15 hover:border-accent">
          Kontakt aufnehmen
        </a>
      </div>

      <button id="mobile-menu-toggle" class="lg:hidden text-white p-2 hover:bg-white/10 rounded-full transition-colors" aria-label="Menü öffnen">
        <Icon name="lucide:menu" id="menu-icon-open" class="w-6 h-6" />
        <Icon name="lucide:x" id="menu-icon-close" class="w-6 h-6 hidden" />
      </button>
    </nav>
  </div>

  <div id="mobile-menu" class="lg:hidden hidden bg-white/95 backdrop-blur-2xl border-t border-gray-100/50 max-h-[80vh] overflow-y-auto">
    <div class="container-custom py-6 space-y-1">
      {navItems.map((item) => (
        <div>
          <a href={item.href} class="block px-4 py-3 text-gray-800 font-medium hover:text-accent hover:bg-accent/5 rounded-xl transition-all">
            {item.label}
          </a>
          {item.children && (
            <div class="pl-4 space-y-0.5">
              {item.children.map((group: any) => (
                <div>
                  <a href={group.href} class="block px-4 py-2 text-sm font-semibold text-primary hover:text-accent rounded-lg transition-all">
                    {group.heading}
                  </a>
                  <div class="pl-4 space-y-0.5">
                    {group.items.map((sub: string) => (
                      <a href={group.href} class="block px-4 py-1.5 text-xs text-gray-500 hover:text-accent hover:bg-accent/5 rounded-lg transition-all">
                        {sub}
                      </a>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          )}
        </div>
      ))}
      <div class="pt-4 flex items-center gap-3">
        <a href="https://www.linkedin.com/company/mpcg-koeln/" target="_blank" rel="noopener" class="w-10 h-10 bg-[#0A66C2] text-white rounded-full flex items-center justify-center" aria-label="LinkedIn">
          <Icon name="lucide:linkedin" class="w-5 h-5" />
        </a>
        <a href="/kontakt" class="btn-primary flex-1 justify-center text-center">Kontakt aufnehmen</a>
      </div>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
  });
</script>
