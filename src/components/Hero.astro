---
import { Icon } from 'astro-icon/components';

interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  ctaText?: string;
  ctaHref?: string;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
  compact?: boolean;
  backgroundImage?: string;
  backgroundVideo?: string;
}

const {
  title,
  subtitle,
  description,
  ctaText,
  ctaHref = '/kontakt',
  secondaryCtaText,
  secondaryCtaHref,
  compact = false,
  backgroundImage,
  backgroundVideo,
} = Astro.props;
---

<section class={`relative ${compact ? 'pt-36 pb-24' : 'min-h-screen flex items-center'} bg-primary overflow-hidden grain`}>
  <!-- Background Video -->
  {backgroundVideo && (
    <div class="absolute inset-0">
      <video
        autoplay
        muted
        loop
        playsinline
        preload="auto"
        class="w-full h-full object-cover"
      >
        <source src={backgroundVideo} type="video/mp4" />
      </video>
      <div class="absolute inset-0 bg-primary/70"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-primary via-primary/20 to-primary/40"></div>
    </div>
  )}
  <!-- Background Image -->
  {backgroundImage && !backgroundVideo && (
    <div class="absolute inset-0">
      <img src={backgroundImage} alt="" class="w-full h-full object-cover opacity-15" />
      <div class="absolute inset-0 bg-gradient-to-br from-primary via-primary/95 to-primary/80"></div>
    </div>
  )}
  <!-- Floating Orbs (always, behind content) -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-1/4 -right-32 w-[500px] h-[500px] bg-accent/[0.07] rounded-full blur-[100px] float-slow"></div>
    <div class="absolute -bottom-20 -left-20 w-[400px] h-[400px] bg-accent-light/[0.05] rounded-full blur-[80px] float-slower"></div>
    {!compact && (
      <div class="absolute top-1/2 left-1/3 w-[300px] h-[300px] bg-blue-400/[0.04] rounded-full blur-[60px] float-slow" style="animation-delay: -3s;"></div>
    )}
  </div>

  <div class="container-custom relative z-10">
    <div class="max-w-4xl">
      {subtitle && (
        <div class="inline-flex items-center gap-2.5 px-4 py-2 bg-white/[0.06] backdrop-blur-md border border-white/[0.08] rounded-full mb-8 fade-in">
          <div class="w-1.5 h-1.5 bg-accent-light rounded-full animate-pulse"></div>
          <span class="text-white/70 text-sm font-medium tracking-wide">{subtitle}</span>
        </div>
      )}

      <h1
        class={`${compact ? 'text-4xl md:text-5xl lg:text-6xl' : 'text-4xl md:text-6xl lg:text-7xl'} font-extrabold text-white leading-[1.08] mb-8 fade-in tracking-tight`}
        set:html={title}
      />

      {description && (
        <p class="text-base md:text-lg text-white/60 max-w-2xl mb-12 leading-relaxed fade-in font-light">
          {description}
        </p>
      )}

      {(ctaText || secondaryCtaText) && (
        <div class="flex flex-col sm:flex-row gap-4 fade-in">
          {ctaText && (
            <a href={ctaHref} class="btn-primary">
              {ctaText}
              <Icon name="lucide:arrow-right" class="w-5 h-5 ml-2" />
            </a>
          )}
          {secondaryCtaText && secondaryCtaHref && (
            <a href={secondaryCtaHref} class="btn-outline-white">
              {secondaryCtaText}
            </a>
          )}
        </div>
      )}
    </div>
  </div>

  {!compact && (
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/30">
      <span class="text-[10px] uppercase tracking-[0.2em] font-medium">Scroll</span>
      <div class="w-5 h-8 border border-white/20 rounded-full flex items-start justify-center p-1">
        <div class="w-1 h-2 bg-white/40 rounded-full animate-bounce"></div>
      </div>
    </div>
  )}
</section>
